@using SafeRoute.ViewModels;
@model LoginViewModel;

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="auth-card fade-up">
    <div class="auth-brand">
        <div class="brand-icon-lg">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h2>Welcome Back</h2>
        <p>Sign in to continue to SafeRoute</p>
    </div>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email Address</label>
            <div class="input-icon-wrapper">
                <i class="fa-solid fa-envelope"></i>
                <input asp-for="Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Password</label>
            <div class="input-icon-wrapper">
                <i class="fa-solid fa-lock"></i>
                <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" autocomplete="current-password" />
                <button type="button" class="password-toggle"><i class="fa-solid fa-eye"></i></button>
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label small text-muted-custom"></label>
            </div>
            <a asp-controller="Account" asp-action="VerifyEmail" class="auth-link small">
                Forgot password?
            </a>
        </div>

        <div class="d-grid mb-3">
            <button type="submit" class="btn btn-auth-primary">
                <i class="fa-solid fa-right-to-bracket me-2"></i> Sign In
            </button>
        </div>

        <div class="auth-footer">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register" class="auth-link">Create Account</a>
        </div>

        <div class="auth-divider">or</div>

        <div class="text-center">
            <a asp-controller="Home" asp-action="Index" class="auth-link small">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to SafeRoute
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
