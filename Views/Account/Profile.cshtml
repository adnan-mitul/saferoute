@model SafeRoute.Models.Users
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Profile Info -->
        <div class="col-lg-4">
            <div class="card glass-card p-4 text-center">
                <div class="mb-3">
                    <div style="width:80px;height:80px;border-radius:50%;background:var(--gradient-primary);display:inline-flex;align-items:center;justify-content:center;">
                        <i class="fa-solid fa-user fa-2x text-white"></i>
                    </div>
                </div>
                <h4 class="fw-bold">@Model.FullName</h4>
                <p class="text-muted mb-1">@Model.Email</p>
                <p class="text-muted small">Member since @Model.JoinedAt.ToString("MMM yyyy")</p>

                <div class="row g-2 mt-3">
                    <div class="col-4">
                        <div class="stat-number" style="font-size:1.5rem;color:var(--accent)">@ViewBag.TotalReports</div>
                        <small class="text-muted">Reports</small>
                    </div>
                    <div class="col-4">
                        <div class="stat-number" style="font-size:1.5rem;color:#00d2d3">@ViewBag.VerifiedReports</div>
                        <small class="text-muted">Verified</small>
                    </div>
                    <div class="col-4">
                        <div class="stat-number" style="font-size:1.5rem;color:var(--warning)">@ViewBag.RatingsGiven</div>
                        <small class="text-muted">Ratings</small>
                    </div>
                </div>
            </div>

            <!-- Edit Profile -->
            <div class="card glass-card p-4 mt-4">
                <h6 class="fw-bold mb-3"><i class="fa-solid fa-pen me-2"></i>Edit Profile</h6>
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success py-2">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger py-2">@TempData["Error"]</div>
                }
                <form asp-action="UpdateProfile" method="post">
                    <div class="mb-3">
                        <label class="form-label small">Full Name</label>
                        <input name="fullName" value="@Model.FullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">Phone Number</label>
                        <input name="phoneNumber" value="@Model.PhoneNumber" class="form-control" placeholder="+880..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">Address</label>
                        <input name="address" value="@Model.Address" class="form-control" placeholder="Your area" />
                    </div>
                    <button type="submit" class="btn btn-primary-glow w-100">Save Changes</button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <!-- Trusted Contacts -->
            <div class="card glass-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0"><i class="fa-solid fa-user-shield me-2 text-accent"></i>Trusted Contacts</h5>
                    <span class="badge bg-secondary">@(((List<SafeRoute.Models.TrustedContact>)ViewBag.Contacts).Count)/5</span>
                </div>

                @{
                    var contacts = (List<SafeRoute.Models.TrustedContact>)ViewBag.Contacts;
                }
                @if (contacts.Any())
                {
                    <div class="row g-2 mb-3">
                        @foreach (var c in contacts)
                        {
                            <div class="col-md-6">
                                <div class="d-flex align-items-center justify-content-between p-3 rounded" style="background:var(--bg-card)">
                                    <div>
                                        <div class="fw-semibold">@c.Name</div>
                                        <small class="text-muted">@c.Phone Â· @c.Relationship</small>
                                    </div>
                                    <form asp-action="DeleteContact" method="post">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (contacts.Count < 5)
                {
                    <form asp-action="AddContact" method="post">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <input name="name" class="form-control form-control-sm" placeholder="Name" required />
                            </div>
                            <div class="col-md-3">
                                <input name="phone" class="form-control form-control-sm" placeholder="+880..." required />
                            </div>
                            <div class="col-md-3">
                                <select name="relationship" class="form-select form-select-sm">
                                    <option value="Family">ðŸ‘¨â€ðŸ‘©â€ðŸ‘§ Family</option>
                                    <option value="Spouse">â¤ï¸ Spouse</option>
                                    <option value="Friend">ðŸ¤ Friend</option>
                                    <option value="Other">ðŸ“Œ Other</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-primary-glow btn-sm w-100"><i class="fa-solid fa-plus me-1"></i>Add</button>
                            </div>
                        </div>
                    </form>
                }
            </div>

            <!-- My Reports -->
            <div class="card glass-card p-4">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-file-lines me-2 text-accent"></i>My Reports</h5>
                @{
                    var reports = (List<SafeRoute.Models.IncidentReport>)ViewBag.Reports;
                }
                @if (reports.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle">
                            <thead>
                                <tr><th>Category</th><th>Location</th><th>Date</th><th>Status</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var r in reports)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@r.Category?.Name</span></td>
                                        <td>@(r.LocationName ?? $"{r.Latitude:F3}, {r.Longitude:F3}")</td>
                                        <td>@r.ReportDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @if (r.Status == "Pending") { <span class="badge bg-warning text-dark">Pending</span> }
                                            else if (r.Status == "Verified") { <span class="badge bg-success">Verified</span> }
                                            else { <span class="badge bg-danger">Rejected</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">You haven't submitted any reports yet.</p>
                }
            </div>
        </div>
    </div>
</div>

