@using Microsoft.AspNetCore.Identity;
@inject SignInManager<Users> signInManager;
@inject UserManager<Users> userManager;

<ul class="navbar-nav ms-2 ps-2 align-items-center border-start border-secondary border-opacity-25">
    @if (signInManager.IsSignedIn(User))
    {
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link text-danger" asp-controller="Admin" asp-action="Dashboard"><i class="fa-solid fa-shield me-1"></i>Admin</a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link position-relative" asp-controller="Account" asp-action="Notifications" title="Notifications">
                <i class="fa-solid fa-bell"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge" id="notifBadge" style="display:none;font-size:0.6rem;">0</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Profile"><i class="fa-solid fa-user-circle me-1 text-accent"></i>Profile</a>
        </li>
        <li class="nav-item ms-1">
            <a class="btn btn-glass btn-sm" asp-controller="Account" asp-action="Logout"><i class="fa-solid fa-right-from-bracket me-1"></i>Logout</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
        </li>
        <li class="nav-item ms-1">
            <a class="btn btn-accent btn-sm" asp-controller="Account" asp-action="Register">Register</a>
        </li>
    }
</ul>

@if (signInManager.IsSignedIn(User))
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/api/Notification/count')
                .then(r => r.json())
                .then(data => {
                    var badge = document.getElementById('notifBadge');
                    if (badge && data.count > 0) {
                        badge.style.display = 'inline';
                        badge.textContent = data.count;
                    }
                }).catch(() => {});
        });
    </script>
}