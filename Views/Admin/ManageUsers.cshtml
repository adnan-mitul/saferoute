@model List<SafeRoute.Models.Users>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-users me-2 text-accent"></i>Manage Users</h2>
        <a asp-action="Dashboard" class="btn btn-glass"><i class="fa-solid fa-arrow-left me-1"></i> Back</a>
    </div>

    <div class="card glass-card p-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Joined</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td><i class="fa-solid fa-user-circle me-2 text-accent"></i>@u.FullName</td>
                            <td>@u.Email</td>
                            <td>@(u.PhoneNumber ?? "â€”")</td>
                            <td>@u.JoinedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

