@model List<SafeRoute.Models.EmergencyService>
@{
    ViewData["Title"] = "Emergency Services";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-hospital me-2 text-accent"></i>Emergency Services</h2>
        <a asp-action="Dashboard" class="btn btn-glass"><i class="fa-solid fa-arrow-left me-1"></i> Back</a>
    </div>

    <!-- Add New -->
    <div class="card glass-card p-4 mb-4">
        <h5 class="fw-bold mb-3">Add New Service</h5>
        <form asp-action="AddEmergency" method="post">
            <div class="row g-3">
                <div class="col-md-2">
                    <select name="Type" class="form-select">
                        <option value="Police">ðŸš” Police</option>
                        <option value="Hospital">ðŸ¥ Hospital</option>
                        <option value="Fire">ðŸš’ Fire Station</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input name="Name" class="form-control" placeholder="Service Name" required />
                </div>
                <div class="col-md-2">
                    <input name="Latitude" type="number" step="0.0001" class="form-control" placeholder="Latitude" required />
                </div>
                <div class="col-md-2">
                    <input name="Longitude" type="number" step="0.0001" class="form-control" placeholder="Longitude" required />
                </div>
                <div class="col-md-2">
                    <input name="ContactNumber" class="form-control" placeholder="Phone" required />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary-glow w-100"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>
        </form>
    </div>

    <!-- List -->
    <div class="card glass-card p-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Contact</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                @if (s.Type == "Police") { <span>ðŸš” Police</span> }
                                else if (s.Type == "Hospital") { <span>ðŸ¥ Hospital</span> }
                                else { <span>ðŸš’ Fire</span> }
                            </td>
                            <td>@s.Name</td>
                            <td>@s.Latitude.ToString("F4"), @s.Longitude.ToString("F4")</td>
                            <td>@s.ContactNumber</td>
                            <td>
                                <form asp-action="DeleteEmergency" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button class="btn btn-sm btn-danger"><i class="fa-solid fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

