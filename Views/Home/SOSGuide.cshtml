@{
    ViewData["Title"] = "SOS Setup Guide";
}

<div class="container py-5" style="max-width:800px">
    <div class="text-center mb-5">
        <span class="badge bg-danger-glow px-3 py-2 fs-6 mb-3">🚨 EMERGENCY GUIDE</span>
        <h2 class="fw-bold">SOS Setup Guide</h2>
        <p class="text-muted">Activate your phone's built-in SOS for maximum protection — works even without internet or apps!</p>
    </div>

    <!-- Samsung -->
    <div class="card glass-card p-4 mb-3">
        <h5 class="fw-bold"><i class="fa-solid fa-mobile-screen me-2"></i>Samsung</h5>
        <ol class="mb-0">
            <li>Go to <b>Settings → Advanced Features → Send SOS Messages</b></li>
            <li>Toggle <b>ON</b></li>
            <li>Add your trusted contacts</li>
            <li>In danger: <b>Press Power button 3 times quickly</b></li>
            <li>SMS with location will be sent automatically to your contacts</li>
        </ol>
    </div>

    <!-- Xiaomi -->
    <div class="card glass-card p-4 mb-3">
        <h5 class="fw-bold"><i class="fa-solid fa-mobile-screen me-2"></i>Xiaomi / Redmi / POCO</h5>
        <ol class="mb-0">
            <li>Go to <b>Settings → Safety & Emergency → Emergency SOS</b></li>
            <li>Toggle <b>ON</b></li>
            <li>Set emergency contacts</li>
            <li>In danger: <b>Press Power button 5 times quickly</b></li>
            <li>Auto-calls 999 + SMS to contacts</li>
        </ol>
    </div>

    <!-- iPhone -->
    <div class="card glass-card p-4 mb-3">
        <h5 class="fw-bold"><i class="fa-brands fa-apple me-2"></i>iPhone</h5>
        <ol class="mb-0">
            <li>Go to <b>Settings → Emergency SOS</b></li>
            <li>Toggle <b>"Call with Side Button"</b> ON</li>
            <li>Set Medical ID & emergency contacts in <b>Health app</b></li>
            <li>In danger: <b>Press Side button 5 times quickly</b></li>
            <li>Auto-calls emergency services + shares location</li>
        </ol>
    </div>

    <!-- Stock Android -->
    <div class="card glass-card p-4 mb-3">
        <h5 class="fw-bold"><i class="fa-brands fa-android me-2"></i>Stock Android (Pixel, OnePlus, etc.)</h5>
        <ol class="mb-0">
            <li>Go to <b>Settings → Safety & Emergency → Emergency SOS</b></li>
            <li>Toggle <b>ON</b></li>
            <li>In danger: <b>Press Power button 5 times quickly</b></li>
            <li>Calls emergency number automatically</li>
        </ol>
    </div>

    <div class="card glass-card p-4 text-center" style="background:linear-gradient(135deg, rgba(108,92,231,0.15), rgba(0,210,211,0.1));">
        <h5 class="fw-bold mb-2">💡 Pro Tip</h5>
        <p class="mb-0">Add the same contacts you've saved in SafeRoute's <b>Trusted Contacts</b> to your phone's Emergency SOS contacts. This ensures they get alerted both from your phone's built-in SOS and from SafeRoute.</p>
    </div>
</div>
